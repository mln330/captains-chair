    },
    "stage": {
      "minLength": 1,
      "title": "Stage",
      "type": "string"
    },
    "role": {
      "minLength": 1,
      "title": "Role",
      "type": "string"
    },
    "runtime": {
      "minLength": 1,
      "title": "Runtime",
      "type": "string"
    },
    "requested_model": {
      "minLength": 1,
      "title": "Requested Model",
      "type": "string"
    },
    "resolved_model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
