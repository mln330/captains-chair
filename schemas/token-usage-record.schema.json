        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Tokens"
    },
    "cached_input_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
