{
  "$defs": {
    "ActionKind": {
      "enum": [
        "report_only",
        "no_action",
        "update_plan",
        "implement",
        "review_pr",
        "repair_pr",
        "merge_pr",
        "create_issue",
        "update_issue",
        "label_issue",
        "retarget_issue",
        "close_issue",
        "maintenance",
        "release",
        "production_deploy",
        "secrets",
        "billing",
        "destructive",
        "force_push",
        "delete_branch"
      ],
      "title": "ActionKind",
      "type": "string"
    },
    "ApplicationSurface": {
      "enum": [
        "web_ui",
        "cli",
        "api",
        "library",
        "data_pipeline",
        "infrastructure_release",
        "custom"
      ],
      "title": "ApplicationSurface",
      "type": "string"
    },
    "CompletionPolicy": {
      "enum": [
        "owner_approval",
        "control_plane_complete",
        "auto_merge"
      ],
      "title": "CompletionPolicy",
      "type": "string"
    },
    "DirectOrchestratorConfig": {
      "additionalProperties": false,
      "description": "Durable board-free orchestration for Codex and portable runtimes.",
      "properties": {
        "board_prefix": {
          "default": "make-it-so",
          "minLength": 1,
          "title": "Board Prefix",
          "type": "string"
        },
        "workers": {
          "$ref": "#/$defs/WorkerAssignments"
        },
        "worker_models": {
          "$ref": "#/$defs/WorkerModelAssignments",
          "default": {
            "captain": "codex/gpt-5.6-terra",
            "coder": "codex/gpt-5.3-codex-spark",
            "reviewer": "codex/gpt-5.6-terra",
            "tester": "codex/gpt-5.6-luna",
            "ux_reviewer": "codex/gpt-5.6-terra",
            "final_reviewer": "codex/gpt-5.6-sol",
            "merger": "codex/gpt-5.6-terra",
            "verifier": "codex/gpt-5.6-terra"
          }
        },
        "max_runtime_seconds": {
          "default": 3600,
          "maximum": 14400,
          "minimum": 60,
          "title": "Max Runtime Seconds",
          "type": "integer"
        },
        "max_retries": {
          "default": 2,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "require_live_completion_validation": {
          "default": true,
          "title": "Require Live Completion Validation",
          "type": "boolean"
        },
        "merge_execution": {
          "default": "worker",
          "enum": [
            "worker",
            "deterministic"
          ],
          "title": "Merge Execution",
          "type": "string"
        },
        "kind": {
          "const": "direct",
          "default": "direct",
          "title": "Kind",
          "type": "string"
        },
        "database_path": {
          "format": "path",
          "title": "Database Path",
          "type": "string"
        },
        "worker_runtime": {
          "default": "external",
          "enum": [
            "external",
            "openclaw",
            "codex"
          ],
          "title": "Worker Runtime",
          "type": "string"
        },
        "executable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executable"
        },
        "lease_seconds": {
          "default": 3600,
          "maximum": 14400,
          "minimum": 30,
          "title": "Lease Seconds",
          "type": "integer"
        },
        "max_dispatch_workers": {
          "default": 1,
          "maximum": 10,
          "minimum": 1,
          "title": "Max Dispatch Workers",
          "type": "integer"
        }
      },
      "required": [
        "workers",
        "database_path"
      ],
      "title": "DirectOrchestratorConfig",
      "type": "object"
    },
    "ExternalWorkboardConfig": {
      "additionalProperties": false,
      "description": "Configuration envelope for an orchestrator supplied by an extension package.",
      "properties": {
        "board_prefix": {
          "default": "make-it-so",
          "minLength": 1,
          "title": "Board Prefix",
          "type": "string"
        },
        "workers": {
          "$ref": "#/$defs/WorkerAssignments"
        },
        "worker_models": {
          "$ref": "#/$defs/WorkerModelAssignments",
          "default": {
            "captain": "codex/gpt-5.6-terra",
            "coder": "codex/gpt-5.3-codex-spark",
            "reviewer": "codex/gpt-5.6-terra",
            "tester": "codex/gpt-5.6-luna",
            "ux_reviewer": "codex/gpt-5.6-terra",
            "final_reviewer": "codex/gpt-5.6-sol",
            "merger": "codex/gpt-5.6-terra",
            "verifier": "codex/gpt-5.6-terra"
          }
        },
        "max_runtime_seconds": {
          "default": 3600,
          "maximum": 14400,
          "minimum": 60,
          "title": "Max Runtime Seconds",
          "type": "integer"
        },
        "max_retries": {
          "default": 2,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "require_live_completion_validation": {
          "default": true,
          "title": "Require Live Completion Validation",
          "type": "boolean"
        },
        "merge_execution": {
          "default": "worker",
          "enum": [
            "worker",
            "deterministic"
          ],
          "title": "Merge Execution",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "executable": {
          "minLength": 1,
          "title": "Executable",
          "type": "string"
        },
        "settings": {
          "additionalProperties": true,
          "title": "Settings",
          "type": "object"
        }
      },
      "required": [
        "workers",
        "kind",
        "executable"
      ],
      "title": "ExternalWorkboardConfig",
      "type": "object"
    },
    "HarnessConfig": {
      "additionalProperties": false,
      "description": "Runtime-neutral harness connection settings.\n\nBuilt-in kinds are validated by the harness registry. Keeping the kind\nopen here lets an installed adapter package add a new runtime without\nchanging the core configuration model.",
      "properties": {
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "executable": {
          "minLength": 1,
          "title": "Executable",
          "type": "string"
        },
        "default_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Agent"
        },
        "timeout_seconds": {
          "default": 3600,
          "maximum": 14400,
          "minimum": 30,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "settings": {
          "additionalProperties": true,
          "title": "Settings",
          "type": "object"
        }
      },
      "required": [
        "kind",
        "executable"
      ],
      "title": "HarnessConfig",
      "type": "object"
    },
    "ModelCapability": {
      "additionalProperties": false,
      "properties": {
        "structured_output": {
          "default": false,
          "title": "Structured Output",
          "type": "boolean"
        },
        "tool_access": {
          "default": false,
          "title": "Tool Access",
          "type": "boolean"
        },
        "token_telemetry": {
          "default": false,
          "title": "Token Telemetry",
          "type": "boolean"
        },
        "supported_efforts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasoningEffort"
          },
          "title": "Supported Efforts",
          "type": "array",
          "uniqueItems": true
        },
        "supported_execution_modes": {
          "default": [
            "standard"
          ],
          "items": {
            "$ref": "#/$defs/ModelExecutionMode"
          },
          "title": "Supported Execution Modes",
          "type": "array",
          "uniqueItems": true
        }
      },
      "title": "ModelCapability",
      "type": "object"
    },
    "ModelExecutionMode": {
      "enum": [
        "standard",
        "pro"
      ],
      "title": "ModelExecutionMode",
      "type": "string"
    },
    "ModelPolicy": {
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "$ref": "#/$defs/ModelProfile"
        },
        "planner": {
          "$ref": "#/$defs/ModelProfile"
        },
        "coder": {
          "$ref": "#/$defs/ModelProfile"
        },
        "reviewer": {
          "$ref": "#/$defs/ModelProfile"
        },
        "comment_adjudicator": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tester": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "final_reviewer": {
          "$ref": "#/$defs/ModelProfile"
        },
        "ux_reviewer": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "profiles": {
          "additionalProperties": {
            "$ref": "#/$defs/ModelProfile"
          },
          "title": "Profiles",
          "type": "object"
        }
      },
      "required": [
        "baseline",
        "planner",
        "coder",
        "reviewer",
        "final_reviewer"
      ],
      "title": "ModelPolicy",
      "type": "object"
    },
    "ModelProfile": {
      "additionalProperties": false,
      "properties": {
        "primary": {
          "$ref": "#/$defs/ModelTarget"
        },
        "fallbacks": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ModelTarget"
          },
          "title": "Fallbacks",
          "type": "array"
        },
        "allow_fallback": {
          "default": true,
          "title": "Allow Fallback",
          "type": "boolean"
        },
        "max_attempts": {
          "default": 2,
          "maximum": 10,
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        },
        "escalation_conditions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Escalation Conditions",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "primary"
      ],
      "title": "ModelProfile",
      "type": "object"
    },
    "ModelQualification": {
      "enum": [
        "untested",
        "shadow",
        "canary",
        "certified",
        "autonomous"
      ],
      "title": "ModelQualification",
      "type": "string"
    },
    "ModelTarget": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent"
        },
        "runtime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "thinking": {
          "$ref": "#/$defs/ReasoningEffort",
          "default": "high"
        },
        "execution_mode": {
          "$ref": "#/$defs/ModelExecutionMode",
          "default": "standard"
        },
        "qualification": {
          "$ref": "#/$defs/ModelQualification",
          "default": "untested"
        },
        "capability": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelCapability"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "max_input_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Input Tokens"
        },
        "max_output_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Output Tokens"
        },
        "max_total_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Total Tokens"
        },
        "local": {
          "default": false,
          "title": "Local",
          "type": "boolean"
        },
        "autonomous_eligible": {
          "default": false,
          "title": "Autonomous Eligible",
          "type": "boolean"
        }
      },
      "required": [
        "model"
      ],
      "title": "ModelTarget",
      "type": "object"
    },
    "NotificationConfig": {
      "additionalProperties": false,
      "description": "Built-in delivery settings plus an extension-owned settings envelope.",
      "properties": {
        "kind": {
          "default": "stdout",
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "route": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Route"
        },
        "webhook_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Webhook Env"
        },
        "executable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executable"
        },
        "settings": {
          "additionalProperties": true,
          "title": "Settings",
          "type": "object"
        }
      },
      "title": "NotificationConfig",
      "type": "object"
    },
    "OpenClawWorkboardConfig": {
      "additionalProperties": false,
      "properties": {
        "board_prefix": {
          "default": "make-it-so",
          "minLength": 1,
          "title": "Board Prefix",
          "type": "string"
        },
        "workers": {
          "$ref": "#/$defs/WorkerAssignments"
        },
        "worker_models": {
          "$ref": "#/$defs/WorkerModelAssignments",
          "default": {
            "captain": "codex/gpt-5.6-terra",
            "coder": "codex/gpt-5.3-codex-spark",
            "reviewer": "codex/gpt-5.6-terra",
            "tester": "codex/gpt-5.6-luna",
            "ux_reviewer": "codex/gpt-5.6-terra",
            "final_reviewer": "codex/gpt-5.6-sol",
            "merger": "codex/gpt-5.6-terra",
            "verifier": "codex/gpt-5.6-terra"
          }
        },
        "max_runtime_seconds": {
          "default": 3600,
          "maximum": 14400,
          "minimum": 60,
          "title": "Max Runtime Seconds",
          "type": "integer"
        },
        "max_retries": {
          "default": 2,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "require_live_completion_validation": {
          "default": true,
          "title": "Require Live Completion Validation",
          "type": "boolean"
        },
        "merge_execution": {
          "default": "deterministic",
          "enum": [
            "worker",
            "deterministic"
          ],
          "title": "Merge Execution",
          "type": "string"
        },
        "kind": {
          "const": "openclaw_workboard",
          "default": "openclaw_workboard",
          "title": "Kind",
          "type": "string"
        },
        "executable": {
          "default": "openclaw",
          "title": "Executable",
          "type": "string"
        },
        "worker_runtimes": {
          "$ref": "#/$defs/WorkerRuntimeAssignments",
          "default": {
            "captain": "openclaw",
            "coder": "openclaw",
            "reviewer": "openclaw",
            "tester": "openclaw",
            "ux_reviewer": "openclaw",
            "final_reviewer": "openclaw",
            "merger": "openclaw",
            "verifier": "openclaw"
          }
        },
        "codex_executable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Codex Executable"
        },
        "make_it_so_command": {
          "default": [
            "make_it_so"
          ],
          "items": {
            "type": "string"
          },
          "title": "Make It So Command",
          "type": "array"
        },
        "auth_source_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Source Agent"
        },
        "dispatch_timeout_seconds": {
          "default": 120,
          "maximum": 900,
          "minimum": 10,
          "title": "Dispatch Timeout Seconds",
          "type": "integer"
        },
        "session_limit": {
          "default": 1000,
          "maximum": 10000,
          "minimum": 1,
          "title": "Session Limit",
          "type": "integer"
        },
        "max_concurrent_subagents": {
          "default": 1,
          "maximum": 4,
          "minimum": 1,
          "title": "Max Concurrent Subagents",
          "type": "integer"
        },
        "dispatch_strategy": {
          "default": "managed_single",
          "enum": [
            "managed_single",
            "workboard"
          ],
          "title": "Dispatch Strategy",
          "type": "string"
        }
      },
      "required": [
        "workers"
      ],
      "title": "OpenClawWorkboardConfig",
      "type": "object"
    },
    "OperationMode": {
      "enum": [
        "disabled",
        "advisory",
        "supervised",
        "autonomous"
      ],
      "title": "OperationMode",
      "type": "string"
    },
    "QAProfile": {
      "additionalProperties": false,
      "properties": {
        "version": {
          "const": 1,
          "default": 1,
          "title": "Version",
          "type": "integer"
        },
        "key": {
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "surfaces": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ApplicationSurface"
          },
          "title": "Surfaces",
          "type": "array",
          "uniqueItems": true
        },
        "checks": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Checks",
          "type": "array"
        },
        "required_tools": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required Tools",
          "type": "array"
        },
        "reviewer_role": {
          "default": "qa_assistant",
          "title": "Reviewer Role",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "title"
      ],
      "title": "QAProfile",
      "type": "object"
    },
    "ReasoningEffort": {
      "enum": [
        "off",
        "none",
        "low",
        "medium",
        "high",
        "xhigh",
        "max"
      ],
      "title": "ReasoningEffort",
      "type": "string"
    },
    "RepoConfig": {
      "additionalProperties": false,
      "properties": {
        "full_name": {
          "pattern": "^[^/\\s]+/[^/\\s]+$",
          "title": "Full Name",
          "type": "string"
        },
        "local_path": {
          "format": "path",
          "title": "Local Path",
          "type": "string"
        },
        "default_branch": {
          "default": "main",
          "title": "Default Branch",
          "type": "string"
        },
        "provisioning": {
          "$ref": "#/$defs/RepositoryProvisioningConfig",
          "default": {
            "enabled": false,
            "visibility": "private",
            "description": ""
          }
        },
        "operation_mode": {
          "$ref": "#/$defs/OperationMode",
          "default": "advisory"
        },
        "completion_policy": {
          "$ref": "#/$defs/CompletionPolicy",
          "default": "owner_approval"
        },
        "allow_autonomous_merge": {
          "default": false,
          "title": "Allow Autonomous Merge",
          "type": "boolean"
        },
        "canonical_docs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Canonical Docs",
          "type": "array"
        },
        "planning_doc": {
          "title": "Planning Doc",
          "type": "string"
        },
        "project_manifest": {
          "default": ".make-it-so/project.yaml",
          "title": "Project Manifest",
          "type": "string"
        },
        "require_project_manifest": {
          "default": false,
          "title": "Require Project Manifest",
          "type": "boolean"
        },
        "checks": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Checks",
          "type": "array"
        },
        "docs_checks": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Docs Checks",
          "type": "array"
        },
        "ux_paths": {
          "default": [
            "frontend/",
            "*.tsx",
            "*.jsx",
            "*.css",
            "*.html"
          ],
          "items": {
            "type": "string"
          },
          "title": "Ux Paths",
          "type": "array"
        },
        "ux_enabled": {
          "default": true,
          "title": "Ux Enabled",
          "type": "boolean"
        },
        "surfaces": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ApplicationSurface"
          },
          "title": "Surfaces",
          "type": "array",
          "uniqueItems": true
        },
        "qa_profiles": {
          "default": [],
          "items": {
            "$ref": "#/$defs/QAProfile"
          },
          "title": "Qa Profiles",
          "type": "array"
        },
        "notification": {
          "$ref": "#/$defs/NotificationConfig",
          "default": {
            "kind": "stdout",
            "route": null,
            "webhook_env": null,
            "executable": null,
            "settings": {}
          }
        },
        "model_profiles": {
          "additionalProperties": {
            "$ref": "#/$defs/ModelProfile"
          },
          "title": "Model Profiles",
          "type": "object"
        },
        "approval_whitelist": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ActionKind"
          },
          "title": "Approval Whitelist",
          "type": "array",
