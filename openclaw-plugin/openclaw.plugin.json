{
  "id": "make-it-so",
  "name": "Make It So",
  "description": "An SDLC control plane that puts the builder in command of an agent crew.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "make_it_so_course_status",
      "make_it_so_resolve_checkpoint",
      "make_it_so_answer_readiness",
      "make_it_so_start_planning",
      "make_it_so_ready_work"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "configPath": {
        "type": "string",
        "description": "Path to the Make It So YAML configuration"
      },
      "pythonExecutable": {
        "type": "string",
        "default": "python3"
      },
      "sidecarCommand": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["-m", "make_it_so.sidecar"]
      },
      "openclawExecutable": {
        "type": "string",
        "default": "openclaw"
      },
      "discordRouteAliases": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "default": {},
        "description": "Map friendly Discord route names such as notifications to explicit OpenClaw Discord targets"
      },
      "installSchedules": {
        "type": "boolean",
        "default": false,
        "description": "Allow the operator to install the two plugin-owned Gateway cron jobs"
      }
    }
  }
}
